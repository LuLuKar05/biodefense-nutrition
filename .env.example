# ═══════════════════════════════════════════════════════════
# Biodefense Nutrition — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values:  cp .env.example .env
# Privacy: user health data NEVER touches the backend.

# ═══════════════════════════════════════════════════════════
# REQUIRED — Core API Keys
# ═══════════════════════════════════════════════════════════

# ── FLock API (LLM brain for all agents) ──
# Get from: https://flock.io → Dashboard → API Keys
FLOCK_API_KEY=
FLOCK_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=qwen3-30b-a3b-instruct-2507

# ── Amina CLI (cloud GPU protein tools) ──
# Get from: https://app.aminoanalytica.com/settings/api
# Install:  pip install amina-cli
# $5 free credit on signup
# Tools used: esmfold, pdb-cleaner, pdb-quality-assessment, p2rank, sasa, diffdock
AMINA_API_KEY=
AMINA_TIMEOUT=600               # Max seconds per job (default: 600)

# ═══════════════════════════════════════════════════════════
# CHANNELS — set at least one
# ═══════════════════════════════════════════════════════════

# ── Telegram ──
# Get from @BotFather on Telegram: /newbot → copy token
TELEGRAM_BOT_TOKEN=

# ── Discord (optional) ──
# Get from https://discord.com/developers/applications → Bot → Token
# Enable: MESSAGE CONTENT INTENT in Bot settings
DISCORD_BOT_TOKEN=

# ── Slack (optional) ──
# Create app at https://api.slack.com/apps
SLACK_BOT_TOKEN=                 # xoxb-...
SLACK_APP_TOKEN=                 # xapp-...

# ── WhatsApp ──
# No token needed — link via QR code: openclaw channels login

# ═══════════════════════════════════════════════════════════
# OPTIONAL — External APIs
# ═══════════════════════════════════════════════════════════

# ── NCBI (faster protein lookups) ──
NCBI_API_KEY=

# ── OpenWeatherMap (AQI data, free tier) ──
# Get from: https://home.openweathermap.org/api_keys
OWM_API_KEY=

# ══════════════════════════════════════════════════════════
# INFRASTRUCTURE (defaults work for local dev)
# ═══════════════════════════════════════════════════════════

# ── OpenClaw Gateway ──
OPENCLAW_HOOKS_TOKEN=            # Shared secret for gateway ↔ webhook auth
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
GATEWAY_BRIDGE_PORT=18790

# ── Threat Backend ──
THREAT_BACKEND_URL=http://127.0.0.1:8100

# ── Docker services (only needed for docker-compose) ──
MONGODB_URI=mongodb://localhost:27017/biodefense
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider for OpenClaw's own agent (optional) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FLOCK_ALLIANCE_KEY=
