# ═══════════════════════════════════════════════════════════
# Biodefense Nutrition — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Privacy: user health data NEVER touches this backend.

# ── Threat Intelligence Backend ──
MONGODB_URI=mongodb://localhost:27017/biodefense
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider (used by OpenClaw's agent) ──
# Set ONE of these — OpenClaw auto-detects the provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OpenClaw Gateway ──
OPENCLAW_HOOKS_TOKEN=            # Shared secret for Celery → OpenClaw webhook alerts
OPENCLAW_GATEWAY_URL=http://localhost:18789  # For Celery workers to POST alerts

# ═══════════════════════════════════════════════════════════
# CHANNEL TOKENS — set the ones you want to enable
# ═══════════════════════════════════════════════════════════

# ── Telegram ──
# Get from @BotFather on Telegram: /newbot → copy token
TELEGRAM_BOT_TOKEN=

# ── Discord ──
# Get from https://discord.com/developers/applications → Bot → Token
# Also enable: MESSAGE CONTENT INTENT in Bot settings
DISCORD_BOT_TOKEN=

# ── WhatsApp ──
# No token needed! Link via QR code:
#   openclaw channels login
# Then scan from WhatsApp → Settings → Linked Devices → Link a Device

# ── Slack ──
# Create app at https://api.slack.com/apps
# Enable Socket Mode, add Bot Token Scopes (chat:write, app_mentions:read, etc.)
SLACK_BOT_TOKEN=                 # xoxb-...
SLACK_APP_TOKEN=                 # xapp-...

# ── Signal (optional) ──
# Requires signal-cli installed: https://github.com/AsamK/signal-cli
# SIGNAL_PHONE_NUMBER=+1234567890

# ── Microsoft Teams (optional) ──
# Requires Azure Bot Framework registration
# MSTEAMS_APP_ID=
# MSTEAMS_APP_PASSWORD=

# ── Google Chat (optional) ──
# Requires Google Cloud project with Chat API enabled
# GOOGLE_CHAT_CREDENTIALS_PATH=./credentials/google-chat.json

# ═══════════════════════════════════════════════════════════
# EXTERNAL APIs (threat intelligence — public data only)
# ═══════════════════════════════════════════════════════════
NCBI_API_KEY=
AQI_API_KEY=
AMINA_API_KEY=
FLOCK_ALLIANCE_KEY=
