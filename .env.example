# ── Database ──
MONGODB_URI=mongodb://localhost:27017/biodefense
REDIS_URL=redis://localhost:6379/0

# ── OpenClaw Gateway ──
TELEGRAM_BOT_TOKEN=              # OpenClaw reads this for channels.telegram
DISCORD_BOT_TOKEN=               # OpenClaw reads this for channels.discord
OPENCLAW_HOOKS_TOKEN=            # Shared secret for Celery → OpenClaw webhook calls
OPENCLAW_GATEWAY_URL=http://localhost:18789  # For Celery workers to POST alerts

# ── LLM Provider (used by OpenClaw's Pi agent) ──
OPENAI_API_KEY=                  # or ANTHROPIC_API_KEY

# ── External APIs ──
NCBI_API_KEY=
AQI_API_KEY=
AMINA_API_KEY=
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=
FLOCK_ALLIANCE_KEY=
